# -------------------------------------------------------
# REQUIRED — Pi-hole web admin password
# -------------------------------------------------------
PIHOLE_PASSWORD=change_me_to_a_strong_password

# -------------------------------------------------------
# OPTIONAL — override defaults if your network is different
# -------------------------------------------------------
# TZ=Europe/Warsaw
# DHCP_START=192.168.1.100
# DHCP_END=192.168.1.200
# DHCP_ROUTER=192.168.1.1
# DHCP_LEASE_TIME=24h
# PIHOLE_DOMAIN=home

# -------------------------------------------------------
# OPTIONAL — local service names served by Pi-hole DNS
# -------------------------------------------------------
# HOMELAB_IP=192.168.1.150
# HOMELAB_DOMAIN=home
# HOMELAB_DNS_NAMES=pihole,glance
# HOMELAB_APPS=glance

# When DHCP_ACTIVE=true, the start script advertises HOMELAB_IP as the DNS
# server via DHCP option 6.
